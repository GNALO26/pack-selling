# ══════════════════════════════════════════════════════
# PACK DIGITAL 360 — VARIABLES FRONTEND (Next.js)
# Copiez en .env.local — NE JAMAIS committer !
# ══════════════════════════════════════════════════════

# URL de votre API backend (Railway en production)
NEXT_PUBLIC_API_URL=http://localhost:5000

# ID MongoDB du Pack Digital 360 (récupéré après npm run seed)
# node -e "require('./utils/seed'); " puis cherchez l'_id dans MongoDB Atlas
NEXT_PUBLIC_PACK_ID=REMPLACER_PAR_L_ID_MONGODB_DU_PACK

# URL du frontend (pour les redirections et CORS)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
